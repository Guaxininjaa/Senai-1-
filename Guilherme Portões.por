programa {
  funcao inicio() {
    real devsCLT
    real estagiarios
    real devsPJ
    real total
    escreva ("devsCLT = ")
    leia (devsCLT)
    
    escreva ("estagiarios = ")
    leia (estagiarios)
    
    escreva ("devsPJ = ")
    leia (devsPJ)

    

    total = devsCLT + estagiarios + devsPJ
    escreva ("\nO total de devs sao:" + total)



  }
}
