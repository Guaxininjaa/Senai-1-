programa {
  funcao inicio() {
    real idadeCachorro, idadeHumano
    

    escreva ("Idade do cachorro: ")
    leia (idadeCachorro)

    idadeHumano = idadeCachorro * 7

    se (idadeHumano >= 65 ){
      escreva ("Pode se aposentar.")
    }senao {
      escreva ("não pode se aposentar.")

    }
  
     
     

  }
}
