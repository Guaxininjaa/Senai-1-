programa {
  funcao inicio() {
    inteiro horas
    real precoTotal, lucro

    escreva ("Quantidade de horas: ")
    leia (horas)
 
        precoTotal = 500 + (horas * 350)
        lucro = precoTotal - 500

           escreva ("Valor a Cobrar: R$" + precoTotal)
           escreva ("\nLucro: R$ " + lucro)






  }
}
