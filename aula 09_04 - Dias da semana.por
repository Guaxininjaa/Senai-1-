programa {
  funcao inicio() {
    inteiro dia
    escreva("Digite o numero do dia: ")
    leia(dia)
    se(dia == 1){
      escreva("Domingo")
      }senao se(dia == 2){
        escreva("segunda")
      }senao se(dia == 3){
        escreva("Terça")
      }senao se(dia == 4){
        escreva ("Quarta")
      }senao se(dia == 5){
        escreva ("Quinta")
      }senao se(dia == 6){
        escreva ("Sexta")
      }senao{
        escreva("Sabado")
      }
    }
  }

