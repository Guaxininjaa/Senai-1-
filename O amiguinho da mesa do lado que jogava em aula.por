programa {
  funcao inicio() {
    inteiro idade

     escreva("Digite sua idade: ")
     leia(idade)

  se(idade < 18){
      escreva("Menor")
      escreva ("\nNão jogue joguinhos idiotinhas aqui!")

  }senao{
    escreva("Maior")
    escreva("\nTem motivo pra entrar no intagram durante a aula?")
  }
  
  }
}
