programa {
  funcao inicio() {
    real inicioLaranja
    real finalLaranja
    real vendidas
    
    escreva ("quantidade inicial de laranja = ")
    leia (inicioLaranja)

    escreva ("Quantidade final de laranjas = ")
    leia (finalLaranja)

    vendidas = inicioLaranja - finalLaranja
    escreva ("\nO total de laranjas vendidas sao = " + vendidas)

  }
}
