programa {
  funcao inicio() {
   real custos 
   real doacoes
   real dizimos 
   real divida
   

   escreva ("Custos Mensais: ")
   leia (custos)

   escreva ("Doações: ")
   leia (doacoes)

   escreva ("Dizimos: ")
   leia (dizimos)

   divida = custos- doacoes - dizimos

   escreva ("\n A pagar: " + divida)
   
  

   
   


  }
}
