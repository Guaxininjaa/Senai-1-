programa {
  funcao inicio() {
      inteiro preco
        real saldo

        escreva("preco: ")
        leia(preco)

        escreva("saldo: ")
        leia(saldo)

        se (saldo >= preco) {
            escreva("Pode comprar")
        } senao {
            
            escreva("\nP   O   B   R   E")
            
            

      }
       


  }
}
